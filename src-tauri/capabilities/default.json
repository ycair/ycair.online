{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "args": [
            { "validator": "\\S+" },
            { "validator": "\\S+" }
          ],
          "cmd": "bin/ycair-core",
          "sidecar": true
        }
      ]
    },
    "shell:allow-execute",
    "log:default"
  ]
}